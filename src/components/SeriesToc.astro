---
import { getCollection, type CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'> | CollectionEntry<'internal'>;
  // Which route we're rendering on. Affects how unpublished entries behave:
  //  - 'blog'     → published linked to /blog/; drafts shown greyed + non-clickable (planned)
  //  - 'internal' → published linked to /blog/; drafts linked to /internal/ (previewable)
  route?: 'blog' | 'internal';
}
const { post, route = 'blog' } = Astro.props;
const series = post.data.series;

type Item = { id: string; title: string; order: number; published: boolean };
let items: Item[] = [];

if (series) {
  const published = (await getCollection('blog'))
    .filter((p) => p.data.series === series && !p.data.draft)
    .map((p) => ({ id: p.id, title: p.data.title, order: p.data.seriesOrder ?? 0, published: true }));
  const drafts = (await getCollection('internal'))
    .filter((p) => p.data.series === series)
    .map((p) => ({ id: p.id, title: p.data.title, order: p.data.seriesOrder ?? 0, published: false }));
  // Merge the full planned series; prefer the published copy if a slug somehow appears in both.
  const byId = new Map<string, Item>();
  for (const it of [...drafts, ...published]) {
    if (!byId.has(it.id) || it.published) byId.set(it.id, it);
  }
  items = [...byId.values()].sort((a, b) => a.order - b.order);
}

const total = items.length;
const order = post.data.seriesOrder ?? 0;

function hrefFor(it: Item): string | null {
  if (it.published) return `/blog/${it.id}/`;
  if (route === 'internal') return `/internal/${it.id}/`;
  return null; // draft on the public route → planned (greyed, not clickable)
}
---

{series && total > 0 && (
  <nav class="series-toc-top" aria-label={`${series} series contents`}>
    <div class="stt-head">
      <span class="stt-kicker">Series</span>
      <span class="stt-title">{series}</span>
      <span class="stt-progress">Part {order || '—'} of {total}</span>
    </div>
    <ol class="stt-list">
      {items.map((it) => {
        const current = it.id === post.id;
        const href = current ? null : hrefFor(it);
        const planned = !current && !href;
        return (
          <li class:list={['stt-item', { current, planned }]} aria-current={current ? 'true' : undefined}>
            {current ? (
              <span><span class="stt-num">{it.order || ''}.</span>{it.title}</span>
            ) : href ? (
              <a href={href}><span class="stt-num">{it.order || ''}.</span>{it.title}</a>
            ) : (
              <span class="stt-planned"><span class="stt-num">{it.order || ''}.</span>{it.title}<span class="stt-soon">soon</span></span>
            )}
          </li>
        );
      })}
    </ol>
  </nav>
)}

<style>
  .series-toc-top {
    margin: 0 0 2em;
    padding: 1em 1.25em;
    border: 1px solid rgb(var(--gray-light));
    border-left: 4px solid var(--accent);
    border-radius: 10px;
    background: rgba(var(--gray-light), 0.25);
  }
  .stt-head {
    display: flex;
    align-items: baseline;
    gap: 0.6em;
    flex-wrap: wrap;
    margin-bottom: 0.6em;
  }
  .stt-kicker {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.68em;
    font-weight: 700;
    color: var(--accent);
  }
  .stt-title { font-weight: 700; color: rgb(var(--gray-dark)); }
  .stt-progress { margin-left: auto; font-size: 0.82em; color: rgb(var(--gray)); }
  .stt-list {
    list-style: none;
    margin: 0;
    padding: 0.4em 0 0;
    border-top: 1px solid rgb(var(--gray-light));
  }
  .stt-item {
    font-size: 0.95em;
    line-height: 1.35;
    padding: 0.2em 0;
  }
  .stt-num {
    display: inline-block;
    min-width: 1.9em;
    color: rgb(var(--gray));
    font-variant-numeric: tabular-nums;
  }
  .stt-list a { color: rgb(var(--gray-dark)); text-decoration: none; }
  .stt-list a:hover { color: var(--accent); text-decoration: underline; }
  .stt-item.current > span { font-weight: 700; color: rgb(var(--black)); }
  .stt-item.current .stt-num { color: var(--accent); }
  /* planned-but-unpublished: greyed, not clickable */
  .stt-item.planned .stt-planned { color: rgb(var(--gray)); cursor: default; }
  .stt-soon {
    margin-left: 0.5em;
    font-size: 0.7em;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
    color: rgb(var(--gray));
    border: 1px solid rgb(var(--gray-light));
    border-radius: 4px;
    padding: 0.05em 0.4em;
    vertical-align: middle;
  }
</style>
