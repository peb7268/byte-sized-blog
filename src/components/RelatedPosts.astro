---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section class="related-posts">
    <h2>Related Posts</h2>
    <div class="related-grid">
      {posts.map((post) => (
        <a href={`/blog/${post.id}/`} class="related-card">
          <div class="related-thumbnail">
            {post.data.heroImage ? (
              <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
            ) : (
              <div class="placeholder-thumb">
                <span>📝</span>
              </div>
            )}
          </div>
          <div class="related-info">
            <h3>{post.data.title}</h3>
            <p class="related-excerpt">{post.data.description}</p>
            <span class="related-date">
              <FormattedDate date={post.data.pubDate} />
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .related-posts {
    width: 720px;
    max-width: calc(100% - 2em);
    margin: 3em auto 2em;
    padding: 0 1em;
  }

  .related-posts h2 {
    font-size: 1.4em;
    margin-bottom: 1.2em;
    color: rgb(var(--gray-dark));
    border-top: 1px solid rgb(var(--gray-light));
    padding-top: 2em;
  }

  .related-grid {
    display: flex;
    gap: 1.5em;
    overflow-x: auto;
    padding-bottom: 0.5em;
  }

  .related-card {
    flex: 0 0 280px;
    text-decoration: none;
    color: inherit;
    border-radius: 12px;
    overflow: hidden;
    background: rgb(var(--gray-gradient));
    box-shadow: var(--box-shadow);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .related-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .related-thumbnail {
    width: 100%;
    height: 160px;
    overflow: hidden;
  }

  .related-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .related-card:hover .related-thumbnail img {
    transform: scale(1.05);
  }

  .placeholder-thumb {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgb(var(--gray-light)), rgb(var(--gray)));
    font-size: 2.5em;
  }

  .related-info {
    padding: 1em;
  }

  .related-info h3 {
    font-size: 0.95em;
    font-weight: 600;
    margin: 0 0 0.4em;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-excerpt {
    font-size: 0.8em;
    color: rgb(var(--gray));
    margin: 0 0 0.6em;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-date {
    font-size: 0.75em;
    color: rgb(var(--gray));
  }

  @media (max-width: 720px) {
    .related-grid {
      flex-direction: column;
      align-items: stretch;
    }

    .related-card {
      flex: 0 0 auto;
    }
  }
</style>
