---
// Minimal personal-brand header. Replaces the byte-sized logo + tagline
// with a small gold "pb" monogram (matches the hero mark on /), thin
// inline nav, and a tight cluster of social links. The chrome stays
// quiet so the hero on / does the introducing.
---

<header class="site-header">
  <nav>
    <a class="mark" href="/" aria-label="Paul Barrick — home">
      <svg viewBox="0 0 40 40" width="32" height="32" role="img" aria-hidden="true">
        <rect x="1" y="1" width="38" height="38" rx="6" fill="#0F1219" />
        <rect x="3" y="3" width="34" height="34" rx="5" fill="none"
          stroke="#D4AF37" stroke-width="0.7" opacity="0.7" />
        <text x="50%" y="56%" text-anchor="middle"
          font-family="Georgia, 'Times New Roman', serif"
          font-size="22" font-weight="700" fill="#D4AF37"
          dominant-baseline="middle">pb</text>
      </svg>
      <span class="mark-name">Paul Barrick</span>
    </a>

    <div class="internal-links">
      <a href="/">Home</a>
      <a href="/blog">Writing</a>
      <a href="/about">About</a>
    </div>

    <div class="social-links" aria-label="Social links">
      <a href="https://www.linkedin.com/in/peb7268/" target="_blank" rel="noopener" title="LinkedIn">
        <span class="sr-only">LinkedIn</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20"
          ><path fill="currentColor"
            d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"
          /></svg>
      </a>
      <a href="https://github.com/peb7268" target="_blank" rel="noopener" title="GitHub">
        <span class="sr-only">GitHub</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20"
          ><path fill="currentColor"
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
          /></svg>
      </a>
    </div>
  </nav>
</header>

<style>
  .site-header {
    background: rgba(250, 250, 250, 0.85);
    backdrop-filter: saturate(140%) blur(8px);
    -webkit-backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid rgba(15, 18, 25, 0.08);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: min(1100px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 0.7rem 1rem;
  }

  .mark {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: #0F1219;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: -0.005em;
  }

  .mark-name {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1.05rem;
  }

  .internal-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .internal-links a {
    color: #2B3243;
    text-decoration: none;
    font-size: 0.92rem;
    transition: color 0.15s ease;
  }
  .internal-links a:hover {
    color: #0F1219;
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .social-links a {
    display: inline-flex;
    color: #2B3243;
    transition: color 0.15s ease;
  }
  .social-links a:hover {
    color: #D4AF37;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 640px) {
    .internal-links {
      gap: 1rem;
    }
    .mark-name {
      display: none;
    }
  }
</style>
