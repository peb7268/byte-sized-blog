---
// Comments via giscus (GitHub Discussions-backed). No server/DB to run — comments
// live in the byte-sized-blog repo's Discussions. Requires the giscus GitHub App
// installed on the repo (github.com/apps/giscus). Rendered only on published posts.
---
<section class="comments" aria-label="Comments">
	<h2>Comments</h2>
	<script
		src="https://giscus.app/client.js"
		data-repo="peb7268/byte-sized-blog"
		data-repo-id="R_kgDOQHhZXg"
		data-category="Announcements"
		data-category-id="DIC_kwDOQHhZXs4DACBL"
		data-mapping="pathname"
		data-strict="0"
		data-reactions-enabled="1"
		data-emit-metadata="0"
		data-input-position="bottom"
		data-theme="preferred_color_scheme"
		data-lang="en"
		data-loading="lazy"
		crossorigin="anonymous"
		async
	></script>
</section>

<style>
	/* Full-width + left-aligned within its wrapper (the .post-comments block in
	   BlogPost owns the width, left edge, top spacing, and separator line). */
	.comments {
		width: 100%;
		margin: 0 0 1em;
		padding: 0;
	}
	.comments h2 {
		font-size: 1.4em;
		margin-bottom: 1rem;
		color: rgb(var(--gray-dark));
	}
</style>
