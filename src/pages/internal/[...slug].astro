---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('internal');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'internal'>;

const post = Astro.props;
const { Content } = await render(post);
---

<BlogPost {...post.data}>
	<div class="internal-banner">
		<span class="badge">Internal</span>
		Authenticated Access Only
	</div>
	<Content />
</BlogPost>

<style>
	.internal-banner {
		background: #1a1a2e;
		color: #e0e0e0;
		border: 1px solid #333;
		border-radius: 8px;
		padding: 0.5em 1em;
		margin-bottom: 1.5em;
		display: flex;
		align-items: center;
		gap: 0.6em;
		font-size: 0.85em;
		font-weight: 500;
	}
	.internal-banner .badge {
		background: #c0392b;
		color: #fff;
		padding: 0.15em 0.5em;
		border-radius: 4px;
		font-size: 0.8em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
</style>
